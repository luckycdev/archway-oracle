# =========================
# App UI
# =========================
APP_PAGE_TITLE=Archway Oracle: St. Louis Traffic Predictive Intelligence & Detector
APP_PAGE_ICON=🚗
APP_PAGE_LAYOUT=wide
LIVE_STATS_REFRESH_INTERVAL=450ms
CAMERA_LIVE_UPDATE_DEFAULT=true

# Commuter recommendation tuning
PATIENCE_MIN=100
PATIENCE_MAX=1000
PATIENCE_DEFAULT=600
PATIENCE_STEP=50
LOOKAHEAD_HOURS=4
WEATHER_SCORE_PENALTY_SNOW=1000
WEATHER_SCORE_PENALTY_RAIN=400
WEATHER_SCORE_PENALTY_GLARE=300
COMMUTE_MINUTES_PER_100_VEHICLES=2.0
COMMUTE_GALLONS_PER_5_MIN=0.05
GAS_PRICE_PER_GALLON=3.25

# =========================
# Data processing
# =========================
DATA_FILE_PATH=stl_traffic_counts.csv
DATA_MIN_YEAR=2023
GPS_LAT_BASE=35.8134
GPS_LAT_SCALE=0.000002778
GPS_LON_BASE=-93.3488
GPS_LON_SCALE=0.000003465

SYNTH_DAYS_BACK=1
SYNTH_DAYS_FORWARD=1
SYNTH_NOISE_MIN=0.85
SYNTH_NOISE_MAX=1.15

MORNING_WEATHER_START_HOUR=6
MORNING_WEATHER_END_HOUR=10
MORNING_SIM_PRECIPITATION=4.5
MORNING_SIM_TEMPERATURE=-2.0

OPEN_METEO_BASE_URL=https://api.open-meteo.com/v1/forecast
OPEN_METEO_LATITUDE=38.6274
OPEN_METEO_LONGITUDE=-90.1982
OPEN_METEO_TIMEOUT_SECONDS=5
WEATHER_FALLBACK_TEMPERATURE=15.0
WEATHER_FALLBACK_PRECIPITATION=0.0
WEATHER_FALLBACK_CLOUD_COVER=0.0

SUN_GLARE_CLOUD_THRESHOLD=30
SUN_GLARE_HOURS=7,8,17,18
HOLIDAY_YEARS=2026

# =========================
# Model training
# =========================
MODEL_RANDOM_STATE=42
MODEL_TEST_SPLIT_RATIO=0.8
MODEL_CV_SPLITS=3
MODEL_SEARCH_ITERATIONS=10
MODEL_PERMUTATION_REPEATS=3
MODEL_SEARCH_N_JOBS=-1
MODEL_SEARCH_VERBOSE=1

# =========================
# Camera catalog + workers
# =========================
CAMERAS_JSON_URL=https://traveler.modot.org/timconfig/feed/desktop/StreamingCams2.json
CAMERAS_JSON_TIMEOUT_SECONDS=15
CAMERA_TRIANGLE_FILTER_ENABLED=true
CAMERA_TRIANGLE_A_LAT=37.846534
CAMERA_TRIANGLE_A_LON=-90.229177
CAMERA_TRIANGLE_B_LAT=39.001320
CAMERA_TRIANGLE_B_LON=-89.708173
CAMERA_TRIANGLE_C_LAT=39.113152
CAMERA_TRIANGLE_C_LON=-91.508391

SYMPY_GROUND_TYPES=python
YOLO_MODEL=yolo26n.pt
YOLO_DEVICE=0 # set to "cpu" for cpu or choose gpu index
YOLO_MAX_VRAM_GB=5.5
YOLO_CONFIDENCE=0.15
YOLO_CLASS_IDS=2,3,5,7
YOLO_PROCESS_MAX_WIDTH=960
YOLO_DETECTION_INTERVAL_FRAMES=2
YOLO_DETECTION_MIN_INTERVAL_SECONDS=0.15

MIN_BOX_BOTTOM_Y_RATIO=0.3
WORKER_IDLE_TIMEOUT_SECONDS=10
CAMERA_BUFFER_SIZE=1
CAMERA_FRAME_DROP_GRABS=1
STREAM_JPEG_QUALITY=75

MOVEMENT_STOPPED_THRESHOLD_PIXELS=0.5
MOVEMENT_SLOW_THRESHOLD_PIXELS=4.0
MOVEMENT_MAX_MATCH_DISTANCE_PIXELS=100.0

ROAD_MASK_STALE_SECONDS=5.0
ROAD_MASK_WARMUP_SECONDS=0.5
ROAD_MASK_FADE_MULTIPLIER=0.95
ROAD_MASK_MIN_VALUE=5
ROAD_LEARNING_MIN_FRAME_RATIO=0.05

FPS_SMOOTHING_ALPHA=0.2
COVERAGE_SMOOTHING_ALPHA=0.2

TRAFFIC_BASELINE_COVERAGE=6.5
TRAFFIC_LIGHT_MAX=2.5
TRAFFIC_MODERATE_MAX=5.0
TRAFFIC_HEAVY_MAX=7.5
PREDICTION_MAX_VEHICLES=2500
WEATHER_PENALTY_SNOW=1.5
WEATHER_PENALTY_RAIN=0.8
WEATHER_PENALTY_GLARE=0.5
VISION_WEIGHT=0.6
PREDICTION_WEIGHT=0.4

PROCESSED_STREAM_BIND_HOST=0.0.0.0
PROCESSED_STREAM_PUBLIC_HOST=127.0.0.1
PROCESSED_STREAM_PORT=5051

# Background camera sampling queue (updates colored camera name badges)
CAMERA_BACKGROUND_SCAN_ENABLED=true
CAMERA_BACKGROUND_SAMPLE_SECONDS=5
CAMERA_BACKGROUND_DWELL_SECONDS=0.25
CAMERA_BACKGROUND_WORKERS=1
CAMERA_BACKGROUND_FRAME_STRIDE=2
CAMERA_CAPTURE_OPEN_TIMEOUT_MS=5000
CAMERA_CAPTURE_READ_TIMEOUT_MS=5000
CAMERA_CAPTURE_RETRY_BACKOFF_SECONDS=60
CAMERA_SUPPRESS_OPENCV_LOGS=true
OPENCV_LOG_LEVEL=SILENT
OPENCV_VIDEOIO_DEBUG=0
OPENCV_FFMPEG_DEBUG=0
OPENCV_FFMPEG_CAPTURE_OPTIONS=loglevel;quiet|rtsp_transport;tcp

# =========================
# Docker / Streamlit runtime
# =========================
SERVER_PORT=8501
SERVER_ADDRESS=0.0.0.0
